# ---------------------------------------------------------------------------
# Neon PostgreSQL connection strings (TEMPLATE - safe to commit)
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values from the Neon dashboard.
#   cp .env.example .env
#
# DATABASE_URL : POOLED connection (host contains "-pooler"). Runtime client.
# DIRECT_URL   : DIRECT / unpooled connection. Prisma Migrate & CLI.
# ---------------------------------------------------------------------------

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxxxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxxxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"
