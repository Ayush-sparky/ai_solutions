// Prisma schema for AI-Solutions
// Docs: https://pris.ly/d/prisma-schema
//
// NOTE (Prisma 7): connection URLs are NOT defined here anymore.
//   - Migrate/CLI datasource URL  -> prisma.config.mjs (uses DIRECT_URL)
//   - Runtime client connection   -> driver adapter in lib/prisma.js (uses DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// Enums
// ===========================================================================

/// Moderation lifecycle for customer Reviews. New reviews start as PENDING and
/// are only shown publicly once an admin sets them to APPROVED. Stored as a
/// native Postgres enum type.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Kind of admin notification. Mirrors the source record that triggered it.
enum NotificationType {
  INQUIRY
  REVIEW
  EVENT_REGISTRATION
}

// ===========================================================================
// Models
// ===========================================================================

/// Sales/contact lead submitted from the public marketing site.
model Inquiry {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  company    String
  country    String
  jobTitle   String
  jobDetails String
  createdAt  DateTime @default(now())
}

/// Customer testimonial that passes through admin moderation before going live.
model Review {
  id         String       @id @default(cuid())
  authorName String
  email      String
  rating     Int // 1-5; range enforced by a Postgres CHECK constraint in the migration.
  content    String
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  // Serves the admin moderation queue: filter by status, order by createdAt.
  @@index([status, createdAt])
}

/// "Notify me about future offerings" sign-up, distinct from active inquiries.
model FutureInterest {
  id             String   @id @default(cuid())
  name           String
  email          String
  areaOfInterest String
  message        String
  createdAt      DateTime @default(now())
}

/// Blog/news article with a draft -> publish workflow.
model Article {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String
  coverImageUrl String?
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Serves the public listing: where published = true order by createdAt desc.
  @@index([published, createdAt])
}

/// Image gallery / portfolio entry shown on the marketing site.
model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
}

/// Event (webinar, conference, demo) listed chronologically by eventDate.
/// The public site splits these into "upcoming" (eventDate in the future) and
/// "past" (eventDate elapsed); upcoming events accept viewer registrations.
model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique // used in the public detail URL /events/<slug>
  description String
  location    String
  eventDate   DateTime
  createdAt   DateTime @default(now())

  registrations EventRegistration[]

  @@index([eventDate])
}

/// A viewer's sign-up for an upcoming Event, submitted from the public event
/// detail page. Surfaced in the admin dashboard with a live notification.
model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  company   String?
  message   String?
  createdAt DateTime @default(now())

  // One sign-up per email per event. Emails are normalised to lowercase in the
  // server action before insert, so this case-sensitive index is effectively
  // case-insensitive (and avoids the schema drift an expression index would cause).
  @@unique([eventId, email])
  // Serves the admin listing: all registrations newest-first, and per-event.
  @@index([eventId, createdAt])
  @@index([createdAt])
}

/// Real-time admin notification for new public submissions (inquiries, reviews,
/// event registrations). One row is created per event; `readAt` tracks whether an
/// admin has seen it, which drives the unread badges and toast counts in the dashboard.
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  entityId  String // id of the source Inquiry / Review the notification points at
  readAt    DateTime? // null = unseen; set when an admin marks it read
  createdAt DateTime         @default(now())

  // Serves the bell/badge queries: filter unread by type, order newest first.
  @@index([readAt, createdAt])
  @@index([type, readAt])
}

/// Back-office administrator account for the secure dashboard.
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
